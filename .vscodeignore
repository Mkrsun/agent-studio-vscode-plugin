# Only the bundled output (dist/*.js) + runtime media ship. Everything below is
# source, tooling, or maps and must NOT be in the .vsix.
.vscode/**
.github/**
node_modules/**

# Self-update channel: prior .vsix builds live here. Must NOT be packaged inside a .vsix.
updates/**

# Source — bundled into dist/ by esbuild
src/**
webview-ui/**
scripts/**
**/*.ts
**/*.tsx

# Maintainer wiki — lives in the repo, not the shipped extension (README stays).
docs/**

# Source maps (incl. dist/*.map)
**/*.map

# Build & repo config
esbuild.mjs
tsconfig*.json
.eslintrc*
.gitignore
.vscodeignore
.env.example
# .env is NOT packaged: this repo is PUBLIC, so its .vsix is a public download, and .env names
# the PRIVATE analytics datastore — shipping it would leak that name. Installs set the submission
# target via the `agentStudio.analyticsRepo` setting (or AGENT_STUDIO_ANALYTICS_REPO env) instead.
.env
