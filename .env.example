# =============================================================================
# Agent Studio — environment overrides
# Copy to `.env` (gitignored) and fill in. Loaded at activation from each
# workspace folder root, then the extension dir. Real shell/CI env always wins
# over this file. Every var here overrides the matching VS Code setting.
# =============================================================================

# ── Content marketplaces ─────────────────────────────────────────────────────
# FULL LIST (preferred). Comma-separated "id:Label:owner/repo" entries.
#   - "owner/repo"            → id + label derived from the repo name
#   - "id:owner/repo"         → label = id
#   - "id:Label:owner/repo"   → all explicit
# A JSON array is also accepted: [{"id":"chile","label":"Chile","repo":"Org/chile-marketplace"}]
AGENT_STUDIO_MARKETPLACES=regional:Regional LatAm:MetLife-Global/regional-marketplace,chile:Chile:MetLife-Global/chile-marketplace,brasil:Brasil:MetLife-Global/brasil-marketplace,mexico:México:MetLife-Global/mexico-marketplace,argentina:Argentina:MetLife-Global/argentina-marketplace,colombia:Colombia:MetLife-Global/colombia-marketplace

# SINGLE-REPO shorthand (used only if AGENT_STUDIO_MARKETPLACES is unset).
# AGENT_STUDIO_MARKETPLACE_REPO=Mkrsun/agentic-studio-assets

# ── Extension self-update (VSIX releases) ────────────────────────────────────
# AGENT_STUDIO_UPDATE_REPO=Mkrsun/agent-studio-vscode-plugin

# ── Analytics datastore (token-usage PRs) ────────────────────────────────────
# AGENT_STUDIO_ANALYTICS_REPO=Mkrsun/meta-repo-latam-ai-intelligence-ecosystem-analytics
